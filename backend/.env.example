# Backend environment variables for production
# Copy this file to .env and fill in your values

# MySQL connection string
DATABASE_URL="mysql://user:password@localhost:3306/haotian_website"

# JWT secret (change in production - use a long random string)
JWT_SECRET="your-jwt-secret-change-me"

# CORS allowed origins for production (comma-separated)
# For Docker deployment: http://frontend:3000
# For manual deployment: https://your-domain.com
CORS_ORIGIN="http://localhost:3000"

# Redis (for caching)
REDIS_URL="redis://localhost:6379"
CACHE_TTL=60

# MeiliSearch (for full-text search)
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="dev-master-key"

# Sentry (for error monitoring)
SENTRY_DSN=""
